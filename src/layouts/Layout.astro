---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import msnLogo from "../assets/logo.png";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Madison Mesh",
	description = "Building a free, community-owned mesh radio network in Madison, Wisconsin.",
} = Astro.props;

const fullTitle = title === "Madison Mesh" ? title : `${title} | Madison Mesh`;
const isHomePage = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="stylesheet" href="/css/main.css" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{fullTitle}</title>
	</head>
	<body>
		<Header />
		{
			!isHomePage && (
				<div class="page-banner" aria-label="MARA Hamfest 2026 invite">
					<div class="page-banner-inner">
						<img src={msnLogo.src} alt="Madison Mesh logo" height="52" width="52" />
						<div class="page-banner-copy">
							<h2>Mesh @ MARA Hamfest 2026</h2>
							<p>Meet up with Mesh enthusiasts and HAM operators in person.</p>
						</div>
						<a
							href="https://w9hsy.org/mara-hamfest-2026/"
							target="_blank"
							rel="noopener noreferrer"
							class="btn btn-sm btn-primary"
						>
							Event details ↗
						</a>
					</div>
				</div>
			)
		}
		<main class="page-content">
			<slot />
		</main>
		<Footer />
	</body>
</html>
