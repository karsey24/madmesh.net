---
import msnLogo from "../assets/logo.png";
---

<div class="page-banner" aria-label="MARA Hamfest 2026 invite">
	<div class="page-banner-inner">
		<img src={msnLogo.src} alt="Madison Mesh logo" height="52" width="52" />
		<div class="page-banner-copy">
			<h2>Mesh @ MARA Hamfest 2026</h2>
			<p>Meet up with Mesh enthusiasts and HAM operators in person.</p>
		</div>
		<a
			href="https://w9hsy.org/mara-hamfest-2026/"
			target="_blank"
			rel="noopener noreferrer"
			class="btn btn-sm btn-primary"
		>
			Event details ↗
		</a>
	</div>
</div>
