---
import msnLogo from "../assets/logo.png";
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-brand">
			<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
				<img src={msnLogo.src} alt="Madison Mesh logo" height="36" width="36" style="border-radius:4px;" />
				<h3 style="margin:0;">Madison Mesh</h3>
			</div>
			<p>Building a community-owned mesh radio<br />network in Madison, Wisconsin.</p>

			<div style="display:flex;align-items:center;gap:0.6rem;margin-top:0.25rem;">
				<a
					href="https://discord.gg/fd3JUZc2CN"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Join Madison Mesh on Discord"
					style="display:inline-flex;align-items:center;justify-content:center;"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 127.14 96.36"
						width="24"
						height="24"
						aria-hidden="true"
					>
						<path
							fill="currentColor"
							d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"
						></path>
					</svg>
				</a>
				&ensp;
				<a
					href="https://github.com/karsey24/madmesh.net"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Madison Mesh on GitHub"
					style="display:inline-flex;align-items:center;justify-content:center;"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1024" fill="none" aria-hidden="true">
						<path
							fill-rule="evenodd"
							clip-rule="evenodd"
							d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"
							transform="scale(64)"
							fill="currentColor"></path>
					</svg>
				</a>
			</div>
		</div>

		<div class="footer-ffa">
			<div class="footer-nav">
				<h4>Get Involved</h4>
				<ul class="larger-bottom">
					<li><a href="/getting-started">Getting Started</a></li>
				</ul>

				<h4>Guides</h4>
				<ul>
					<li><a href="/coverage">Antenna and LoRa info</a></li>
					<li><a href="/build-a-node">Build a Node</a></li>
				</ul>
			</div>

			<div class="footer-nav">
				<h4>Resources</h4>
				<ul>
					<li><a href="/host-a-node">Host a Node</a></li>
					<li>
						<a href="https://meshtastic.org/" target="_blank" rel="noopener noreferrer"
							>Meshtastic ↗</a
						>
					</li>
					<li>
						<a href="https://meshcore.co.uk/" target="_blank" rel="noopener noreferrer">MeshCore ↗</a>
					</li>
				</ul>
			</div>

			<div class="footer-nav">
				<h4>Explore</h4>
