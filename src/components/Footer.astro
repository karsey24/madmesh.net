---
import msnLogo from "../assets/logo.png";
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-brand">
			<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
				<img src={msnLogo.src} alt="Madison Mesh logo" height="36" width="36" style="border-radius:4px;" />
				<h3 style="margin:0;">Madison Mesh</h3>
			</div>
			<p>Building a free, community-owned mesh radio<br />network in Madison, Wisconsin.</p>
		</div>

		<div class="footer-ffa">
			<div class="footer-nav">
				<h4>Get Involved</h4>
				<ul class="larger-bottom">
					<li><a href="/getting-started">Getting Started</a></li>
				</ul>

				<h4>Guides</h4>
				<ul>
					<li><a href="/coverage">Coverage</a></li>
					<li><a href="/build-a-node">Build a Node</a></li>
				</ul>
			</div>

			<div class="footer-nav">
				<h4>Resources</h4>
				<ul>
					<li><a href="/host-a-node">Host a Node</a></li>
					<li>
						<a href="https://discord.gg/fd3JUZc2CN" target="_blank" rel="noopener noreferrer"
							>Discord</a
						>
					</li>
				</ul>
			</div>

			<div class="footer-nav">
				<h4>Explore</h4>
				<ul>
					<li>
						<a href="https://meshtastic.org/" target="_blank" rel="noopener noreferrer"
							>Meshtastic ↗</a
						>
					</li>
					<li>
						<a href="https://meshcore.co.uk/" target="_blank" rel="noopener noreferrer">MeshCore ↗</a>
					</li>
					<li>
						<a href="https://meshconsin.org/" target="_blank" rel="noopener noreferrer"
							>Meshconsin ↗</a
						>
					</li>
					<li><a href="/other-meshes">Other Meshes</a></li>
				</ul>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		Website inspired by <a href="https://www.austinmesh.org/" target="_blank" rel="noopener noreferrer"
			>Austin Mesh</a
		> and maintained with &#10084; by the Madisonians under <a
			href="https://creativecommons.org/licenses/by-sa/4.0/"
			target="_blank"
			rel="noopener noreferrer">Creative Commons Attribution-ShareAlike 4.0</a
		>. Hosted by <a href="https://donut.rodeo/">Donut Rodeo</a>.
	</div>
</footer>
