---
import msnLogo from "../assets/logo.png";

const currentPath = Astro.url.pathname;

const isActive = (href: string) => currentPath === href || (href !== "/" && currentPath.startsWith(href));
---

<header class="site-nav">
	<div class="nav-inner">
		<a href="/" class="nav-brand">
			<img src={msnLogo.src} alt="" aria-hidden="true" height="28" width="28" />
			Madison Mesh
		</a>

		<button
			type="button"
			class="nav-toggle"
			aria-expanded="false"
			aria-controls="main-nav"
			aria-label="Toggle navigation menu"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="16"
				height="16"
				fill="currentColor"
				class="bi bi-list"
				viewBox="0 0 16 16"
			>
				<path
					fill-rule="evenodd"
					d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"
				></path>
			</svg>
		</button>

		<nav id="main-nav" class="nav-menu" aria-label="Main navigation">
			<ul class="nav-links">
				<li>
					<a href="/" aria-current={currentPath === "/" ? "page" : undefined}>Home</a>
				</li>
				<li>
					<a href="/getting-started" aria-current={isActive("/getting-started") ? "page" : undefined}
						>Get Started</a
					>
				</li>

				<li class="nav-dropdown">
					<details>
						<summary>Guides & Info</summary>
						<ul class="dropdown-menu">
							<li>
								<a href="/coverage" aria-current={isActive("/coverage") ? "page" : undefined}
									>Coverage</a
								>
							</li>
							<li>
								<a
									href="/build-a-node"
									aria-current={isActive("/build-a-node") ? "page" : undefined}
									>Build a Node</a
								>
							</li>
							<li>
								<a
									href="/host-a-node"
									aria-current={isActive("/host-a-node") ? "page" : undefined}>Host a Node</a
								>
							</li>
						</ul>
					</details>
				</li>

				<li class="nav-dropdown">
					<details>
						<summary>Tools</summary>
						<ul class="dropdown-menu">
							<li>
								<a href="https://msn.meshmapper.net/" target="_blank" rel="noopener noreferrer"
									>Live MeshCore Map ↗</a
								>
							</li>
							<li>
								<a
									href="https://analyzer.letsmesh.net/"
									target="_blank"
									rel="noopener noreferrer">Live MeshCore Packet Viewer ↗</a
								>
							</li>
							<li>
								<a
									href="https://www.heywhatsthat.com/"
									target="_blank"
									rel="noopener noreferrer">LOS calculator ↗</a
								>
							</li>
						</ul>
					</details>
				</li>

				<li>
					<a href="/other-meshes" aria-current={isActive("/other-meshes") ? "page" : undefined}
						>Other Meshes</a
					>
				</li>

				<li>
					<a
						href="https://discord.gg/fd3JUZc2CN"
						target="_blank"
						rel="noopener noreferrer"
						title="Join our Discord"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 127.14 96.36"
							style="height:14px;width:14px;display:inline-block;vertical-align:middle;"
							aria-hidden="true"
						>
							<path
								fill="currentColor"
								d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"
							></path>
						</svg>
						Discord
					</a>
				</li>
			</ul>
		</nav>
	</div>
</header>

<script is:inline>
	(() => {
		const nav = document.querySelector(".site-nav");
		if (!nav) return;

		const toggle = nav.querySelector(".nav-toggle");
		const menu = nav.querySelector(".nav-menu");
		if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

		const dropdowns = Array.from(nav.querySelectorAll(".nav-dropdown details"));

		const closeMenu = () => {
			menu.classList.remove("is-open");
			toggle.setAttribute("aria-expanded", "false");
		};

		toggle.addEventListener("click", () => {
			const isOpen = menu.classList.toggle("is-open");
			toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
			if (!isOpen) {
				dropdowns.forEach((dropdown) => {
					dropdown.open = false;
				});
			}
		});

		dropdowns.forEach((current) => {
			current.addEventListener("toggle", () => {
				if (!current.open) return;
				dropdowns.forEach((other) => {
					if (other !== current) other.open = false;
				});
			});
		});

		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Node)) return;
			if (nav.contains(target)) {
				if (target instanceof Element && target.closest(".nav-menu a")) {
					closeMenu();
					dropdowns.forEach((dropdown) => {
						dropdown.open = false;
					});
				}
				return;
			}
			closeMenu();
			dropdowns.forEach((dropdown) => {
				dropdown.open = false;
			});
		});

		document.addEventListener("keydown", (event) => {
			if (event.key !== "Escape") return;
			closeMenu();
			dropdowns.forEach((dropdown) => {
				dropdown.open = false;
			});
		});

		window.addEventListener("resize", () => {
			if (window.innerWidth > 768) {
				closeMenu();
			}
		});
	})();
</script>
