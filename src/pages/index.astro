---
import Layout from "../layouts/Layout.astro";
import SingleImageBox from "../components/SingleImageBox.astro";
import GalleryBox from "../components/GalleryBox.astro";
import nodeEaveIHateComputers from "../assets/node-eave-iHateComputers.jpg";
import outdoorNodeGutsIHateComputers from "../assets/outdoor-node-guts-iHateComputers.jpg";
import tinyHandheldNodeCloseupOrum from "../assets/tiny-handheld-node-closeup-Orum.jpg";
---

<Layout title="Madison Mesh" description="Building a decentralized mesh radio network in Madison, Wisconsin.">
	<!-- Hero Banner -->
	<section class="hero-banner" aria-label="Site hero">
		<div class="hero-slides" aria-hidden="true">
			<div class="hero-slide hero-slide-capitol"></div>
			<div class="hero-slide hero-slide-background"></div>
			<div class="hero-slide hero-slide-state"></div>
			<div class="hero-slide hero-slide-terrace"></div>
		</div>
		<div class="hero-overlay"></div>
		<div class="hero-content">
			<h1>We're building a decentralized mesh radio network in Madison</h1>
			<p>
				Madison Mesh is a community of radio hobbyists connecting our city through decentralized, off-grid
				communication technology <i>without</i> cell towers or internet.
			</p>
			<div class="hero-actions">
				<a href="/getting-started" class="btn btn-primary">Get Started</a>
				<a
					href="https://discord.gg/fd3JUZc2CN"
					target="_blank"
					rel="noopener noreferrer"
					class="btn btn-outline"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 127.14 96.36"
						style="height:18px;width:auto;"
						aria-hidden="true"
					>
						<path
							fill="currentColor"
							d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"
						></path>
					</svg>
					Join our Discord
				</a>
			</div>
		</div>
		<div class="hero-credit" aria-label="Hero image copyright">
			<span class="hero-credit-item hero-credit-capitol">© Photo: Lizzy Larson</span>
			<span class="hero-credit-item hero-credit-state">© Photo: Sam Askling</span>
			<span class="hero-credit-item hero-credit-terrace">© Photo: Sam Askling</span>
			<span class="hero-credit-item hero-credit-background">© Photo: Karsey Renfert</span>
		</div>
	</section>

	<!-- What is Madison Mesh -->
	<div class="container">
		<section class="section">
			<h1>What do we do?</h1>
			<p>
				Madison Mesh is a local community of hobbyists who use "mesh" radio technologies to communicate.
				Mesh radios pass messages through a network of nodes, allowing communication without relying on
				traditional infrastructure like cell towers or internet connections.
				<br />
				<br />
				We primarily use <a href="https://meshcore.co.uk/" target="_blank" rel="noopener noreferrer"
					>MeshCore</a
				>
				and <a href="https://meshtastic.org/" target="_blank" rel="noopener noreferrer">Meshtastic</a>. Both
				are open-source software that run on affordable LoRa radios you can buy for under $50.
			</p>

			<hr class="divider" />

			<!-- How do I join? -->
			<section class="section">
				<h1>How do I join?</h1>
				<p>
					All you need to get started is a LoRa radio ($35&ndash;$50). Visit our
					<a href="/getting-started">Getting Started</a> guide for a full walkthrough from buying hardware
					to sending your first message on the mesh.
					<br />
					<br />
					Madison Mesh primarily uses <strong>MeshCore</strong> hardware, but we also have members on Meshtastic.
					Both projects support a lot of the same devices, so you don&rsquo;t need to worry about picking the
					&ldquo;right&rdquo; one upfront.
					<br />
					<br />
					<strong class="text-secondary"
						>We are actively growing the network &mdash; every new node helps! Please join us.</strong
					>
				</p>
				<a href="/getting-started" class="btn btn-primary">See the Getting Started Guide &rarr;</a>
			</section>

			<GalleryBox
				images={[
					{
						src: nodeEaveIHateComputers.src,
						alt: "Mounted outdoor mesh node installed along a roof eave",
					},
					{
						src: outdoorNodeGutsIHateComputers.src,
						alt: "A look inside an outdoor mesh node",
					},
					{
						src: tinyHandheldNodeCloseupOrum.src,
						alt: "Close-up of a tiny handheld mesh node",
					},
				]}
			/>

			<iframe
				src="https://msn.meshmapper.net/embed.php"
				width="100%"
				height="400"
				style="border: none; margin-top: 2em;"
				loading="lazy"
			>
			</iframe>
		</section>
	</div>
</Layout>
